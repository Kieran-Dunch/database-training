-- Database Triggers
-- a database trigger is a procedural code that is automatically executed in
-- response to certain events on a particular table or view in a database.

-- So when an event occurs, the trigger is activated (or "fired") and the
-- associated code is executed.

-- Why is this useful?
-- Triggers can be used to enforce business rules, maintain data integrity,
-- and automate system tasks.

-- Example: Let's say we have a table called "orders" and we want to keep
-- track of the total number of orders placed by each customer in a separate
-- table called "customer_order_count".
-- We can create a trigger that automatically updates the "customer_order_count"
-- table whenever a new order is inserted into the "orders" table.

-- Create the "orders" table
CREATE TABLE orders (
    order_id INTEGER PRIMARY KEY,
    customer_id INTEGER,
    order_date TEXT
);

-- Create the "customer_order_count" table
CREATE TABLE customer_order_count (
    customer_id INTEGER PRIMARY KEY,
    order_count INTEGER DEFAULT 0
);

-- Create the trigger
CREATE TRIGGER update_order_count
AFTER INSERT ON orders
BEGIN
    INSERT INTO customer_order_count (customer_id, order_count)
    VALUES (NEW.customer_id, 1)
    ON CONFLICT(customer_id) DO UPDATE SET
    order_count = order_count + 1;
END;

-- Now, whenever a new order is inserted into the "orders" table,
-- the "customer_order_count" table will be automatically updated.

-- Writing your own trigger
-- You can create your own triggers using the CREATE TRIGGER statement.

-- you can also use a triggger to execute a previously made function

-- Example of using a trigger to call a function

CREATE TRIGGER insert_trigger
BEFORE INSERT ON customers
FOR EACH ROW
EXECUTE PROCEDURE insert_function();

SELECT * FROM customers;

INSERT INTO customers (first_name, last_name)
VALUES ('John', 'Doe');

SELECT * FROM customers;

-- when is a trigger activated?
-- A trigger can be activated before or after an INSERT, UPDATE, or DELETE
-- operation.

CREATE TRIGGER after_trigger
AFTER UPDATE ON customers
FOR EACH ROW -- this means the trigger will execute once for each row affected
EXECUTE PROCEDURE log_customers_change();

UPDATE customers
SET years_old = years_old + 10
WHERE customer_id = 1;

SELECT * FROM customers
ORDER BY customer_id;

SELECT * FROM customers_log;

-- this code records changes to the customers table in a log table
-- we use the trigger to call a function that inserts a record

-- FOR EACH ROW or FOR EACH STATEMENT
-- A trigger can be defined to execute either FOR EACH ROW or FOR EACH STATEMENT.
-- FOR EACH ROW means the trigger will execute once for each row affected by the operation,
-- while FOR EACH STATEMENT means the trigger will execute once for the entire operation,
-- regardless of how many rows are affected.

SELECT * FROM customers;

-- Example of FOR EACH STATEMENT trigger
-- This trigger only runs once per UPDATE statement, not once per row affected
CREATE TRIGGER each_statement_trigger
AFTER UPDATE ON customers
FOR EACH STATEMENT
EXECUTE PROCEDURE statement_function();

UPDATE customers
SET years_old = years_old + 1;

SELECT * FROM customers;

-- this is great for making audit triggers that log when a table was modified
-- without needing to log every single row change

-- FOCUS SQL Triggers

-- You can use a WHEN clause to filter when a trigger calls for its function

-- NEW and OLD keywords allow you to access data before and after the execution
-- of the query

-- this trigger can detect when a customer has spent more than $1000 and call a
-- function to log that information or take some action
CREATE TRIGGER insert_trigger_high
BEFORE INSERT ON clients
FOR EACH ROW
WHEN (NEW.total_spent > 1000)
EXECUTE PROCEDURE high_spender();

-- this trigger can detect when a customer has spent less than $1000 and call a
-- function to log that information or take some action
CREATE TRIGGER insert_trigger_low
BEFORE INSERT ON clients
FOR EACH ROW
WHEN (NEW.total_spent < 1000)
EXECUTE PROCEDURE not_a_high_spender();

-- Example trigger using NEW and OLD keywords
CREATE TRIGGER update_trigger_high
BEFORE UPDATE ON clients
FOR EACH ROW
WHEN (NEW.total_spent > 1000)
EXECUTE PROCEDURE set_high_spender();


CREATE TRIGGER update_trigger_low
BEFORE UPDATE ON clients
FOR EACH ROW
WHEN (NEW.total_spent < 1000)
EXECUTE PROCEDURE set_low_spender();

-- The clients existing in the database before the triggers were created will
-- not have their total_spent values updated automatically
SELECT *
FROM clients
ORDER BY client_id;

-- Now, when we update the total_spent for a client, the appropriate trigger\
-- will be activated
UPDATE clients
SET total_spent = 5000
WHERE last_name = 'Campbell';
-- Cambell is now a high spender, so the update_trigger_high will be activated

-- and now for a low spender
UPDATE clients
SET total_spent = 100
WHERE last_name = 'Lewis';

SELECT *
FROM clients
ORDER BY client_id;

-- Nuances of triggers
-- multiple triggers can exist on the same table of the same kind
-- Triggers are then activated in alphabetical order based on their names
-- No trigger can be set on a select statement, only on insert, update, or
-- delete statements

-- Now what happens if a trigger causes another trigger to activate? This is
-- called a cascading trigger.

-- DROP TRIGGER trigger_name; -- this is how you can drop a trigger if you no
-- longer need it

-- to view all existing triggers in the database, you can query the
-- information_schema.triggers table

-- this will print all the triggers
SELECT *
FROM information_schema.triggers;

-- example of dropping a trigger
DROP TRIGGER update_order_count;


-- Quick review:
-- Triggers are associated with a specific table, view or foreign table.

-- Triggers execute a specified function when certain operations are performed
-- on the table (INSERT, UPDATE, DELETE, TRUNCATE).

-- Triggers can run before, after or instead of the operation attempts to alter
-- the row.

-- A trigger set FOR EACH ROW is called once for every row modified.

-- FOR EACH STATEMENT executes once for the entire operation (0 modified rows
-- would still trigger this).

-- Triggers can specify a boolean WHEN condition to see when they should be
-- fired.

-- Multiple triggers of the same kind can exist on the same table. If so they
-- are triggered in alphabetical order.

-- SELECT statements do not modify rows so no trigger can be set on a SELECT
-- statement.

-- One SQL command can trigger more than one kind of trigger.

-- Use the DROP TRIGGER command to remove a trigger.

-- You can query the information_schema.triggers table to get a list of triggers
-- in the system.
